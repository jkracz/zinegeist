{
	"name": "zinegeist",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "concurrently -n web,convex -c blue,magenta \"vite dev --port 5296\" \"bunx convex dev\"",
		"dev:web": "vite dev --port 5296",
		"build:vercel": "bunx convex deploy --cmd 'bun run build' --cmd-url-env-var-name PUBLIC_CONVEX_URL",
		"build": "vite build",
		"preview": "vite preview --port 5296",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"typecheck:convex": "bunx convex typecheck",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/inter": "^5.2.8",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.14.0",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"concurrently": "^9.2.1",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"mode-watcher": "^1.1.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"svelte-sonner": "^1.1.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.3",
		"vite": "^8.0.12"
	},
	"dependencies": {
		"@convex-dev/aggregate": "^0.2.1",
		"@convex-dev/better-auth": "^0.12.2",
		"@convex-dev/polar": "^0.9.1",
		"@embedpdf/core": "^2.14.2",
		"@embedpdf/engines": "^2.14.2",
		"@embedpdf/plugin-document-manager": "^2.14.2",
		"@embedpdf/plugin-render": "^2.14.2",
		"@embedpdf/plugin-scroll": "^2.14.2",
		"@embedpdf/plugin-spread": "^2.14.2",
		"@embedpdf/plugin-viewport": "^2.14.2",
		"@embedpdf/plugin-zoom": "^2.14.2",
		"@mmailaender/convex-better-auth-svelte": "^0.7.4",
		"@mmailaender/convex-svelte": "^0.19.0",
		"better-auth": "1.6.10",
		"convex": "^1.38.0",
		"convex-helpers": "^0.1.116",
		"nanoid": "^5.1.11",
		"posthog-js": "^1.373.2",
		"posthog-node": "^5.33.7"
	}
}
